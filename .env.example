# Скопируй в .env или запусти ./install.sh — он создаст .env сам.
# ============================================================

# Режим: ssl (HTTPS + Let's Encrypt) или http (порт 8080 без SSL)
DEPLOY_MODE=ssl

# Домен (A-запись должна указывать на сервер). Для ssl обязателен.
DOMAIN=example.com
BASE_URL=https://example.com

# Email для Let's Encrypt
ACME_EMAIL=admin@example.com

# Telegram: токен от @BotFather
TELEGRAM_TOKEN=123456:ABC-DEF...

# Секрет webhook (любая длинная случайная строка)
TELEGRAM_WEBHOOK_SECRET=change_me_random_64_chars

# Супер-админы: chat_id через запятую (свой id: напиши боту /myid)
TELEGRAM_SUPER_ADMINS=5820902474

# MySQL
DB_NAME=kleinanzeigen_login
DB_USER=klein
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# Порт для режима http (без Caddy)
HTTP_PORT=8080

# Авто-setup (схема + webhook) при старте контейнера: 1/0
SETUP_ON_START=1
