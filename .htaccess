DirectoryIndex index.php

RewriteEngine On

# /123123 → index.php (suffix ссылки)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(api|assets)(/|$) - [L]
RewriteRule ^[a-zA-Z0-9]{4,32}/?$ index.php [L,QSA]

# Запрет доступа к внутренним каталогам через HTTP
RewriteRule ^(config|lib|db)(/|$) - [F,L]

<FilesMatch "\.(sql|md|example|env)$">
  Require all denied
</FilesMatch>

<FilesMatch "^(\.env|\.setup_done|install\.sh|webhook\.sh|docker-compose\.yml)">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
